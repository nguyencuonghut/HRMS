exec("""
import asyncio
from datetime import date
from io import BytesIO
import openpyxl
from sqlalchemy import delete, select, text
from sqlalchemy.ext.asyncio import async_sessionmaker, create_async_engine
from app.core.config import settings
from app.models.employee import Employee
from app.models.employee_code import EmployeeCodeSequence
from app.services import employee_service, leave_record_import_service
from app.schemas.employee import EmployeeCreate
YEAR = 2096
PREFIX = 'RTLEAVE23'
engine = create_async_engine(settings.DATABASE_URL, connect_args={'ssl': False})
Session = async_sessionmaker(engine, expire_on_commit=False)
async def get_sequence(code):
    async with Session() as s:
        return (await s.execute(select(EmployeeCodeSequence).where(EmployeeCodeSequence.code == code))).scalar_one()
async def create_employee(id_number, employee_seq, status='official', resigned_date=None):
    sequence = await get_sequence('SYS1')
    payload = EmployeeCreate(employee_seq=employee_seq, employee_code_sequence_id=sequence.id, full_name=f'Leave Probe {id_number}', last_name='Leave', first_name=id_number, date_of_birth='1990-01-01', gender='male', nationality_id=1, id_number=id_number, id_issued_on='2020-01-01', id_issued_by='Cuc Canh sat', status=status, start_date='2026-01-01', resigned_date=resigned_date)
    async with Session() as s:
        employee = await employee_service.create_employee(s, payload)
        await s.commit()
        await s.refresh(employee)
        return employee.id
async def main():
    async with Session() as s:
        await s.execute(text(f'DELETE FROM leave_records WHERE EXTRACT(year FROM start_date) = {YEAR}'))
        await s.execute(text(f'DELETE FROM leave_entitlements WHERE year = {YEAR}'))
        employee_ids = [e.id for e in (await s.execute(select(Employee))).scalars().all() if e.id_number and e.id_number.startswith(PREFIX)]
        if employee_ids:
            await s.execute(delete(Employee).where(Employee.id.in_(employee_ids)))
        await s.commit()
    await create_employee(f'{PREFIX}A', 9601)
    await create_employee(f'{PREFIX}R', 9602, status='resigned', resigned_date=date(2026, 12, 31))
    wb = openpyxl.Workbook()
    ws = wb.active
    ws.append(['Mã nhân viên', 'Hệ mã nhân viên', 'Mã loại phép', 'Ngày bắt đầu', 'Ngày kết thúc', 'Ghi chú'])
    ws.append(['9601', 'SYS1', 'annual_leave', f'01/06/{YEAR}', f'03/06/{YEAR}', 'active'])
    ws.append(['9602', 'SYS1', 'annual_leave', f'05/06/{YEAR}', f'05/06/{YEAR}', 'resigned'])
    buf = BytesIO(); wb.save(buf)
    async with Session() as s:
        result = await leave_record_import_service.process_import(s, buf.getvalue())
        await s.commit()
        print({'total': result.total, 'success': result.success, 'failed': result.failed, 'created_ids': result.created_ids})
    async with Session() as s:
        rows = (await s.execute(text('SELECT e.full_name, e.status, lr.entitlement_id, le.year, le.used_days FROM leave_records lr JOIN employees e ON e.id = lr.employee_id LEFT JOIN leave_entitlements le ON le.id = lr.entitlement_id WHERE EXTRACT(year FROM lr.start_date) = :year AND e.full_name LIKE :prefix ORDER BY e.full_name'), {'year': YEAR, 'prefix': f'Leave Probe {PREFIX}%'})).fetchall()
        print([tuple(r) for r in rows])
    await engine.dispose()
asyncio.run(main())
""")
