# HRMS Environment Variables — copy sang .env và điền giá trị thực
# KHÔNG commit file .env vào git

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | lan | staging | production
APP_TIMEZONE=Asia/Ho_Chi_Minh
DEBUG=false
COMPANY_NAME=Công ty Hồng Hà

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=hrms

# DB Connection Pool (tuned for ~200 concurrent users)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true

# ── Security ──────────────────────────────────────────────────────────────────
# Sinh: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_USE_RANDOM_64_CHAR_HEX

# Sinh Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY

# Docker image source
#
# Mặc định dùng tag local để tránh việc copy `.env.example` rồi chạy ngay
# trên server nội bộ/LAN bị lỗi pull từ `ghcr.io`.
# Khi build local:
#   docker build -t hrms-backend:local ./backend
#   docker build -t hrms-frontend:local ./frontend
#   docker build -t hrms-backup:local -f docker/backup/Dockerfile .
#
# Nếu dùng registry-based deploy (ví dụ GHCR), override lại:
# BACKEND_IMAGE=ghcr.io/nguyencuonghut/hrms/hrms-backend
# BACKUP_IMAGE=ghcr.io/nguyencuonghut/hrms/hrms-backup
# FRONTEND_IMAGE=ghcr.io/nguyencuonghut/hrms/hrms-frontend
# IMAGE_TAG=latest hoặc commit SHA đã build/push
BACKEND_IMAGE=hrms-backend
BACKUP_IMAGE=hrms-backup
FRONTEND_IMAGE=hrms-frontend
IMAGE_TAG=local

# Refresh token cookie:
# Dev HTTP local: false
# LAN HTTP-only: false
# Production HTTPS: bắt buộc true
REFRESH_TOKEN_COOKIE_SECURE=false

# ── Redis / Celery ────────────────────────────────────────────────────────────
# Dev: không cần password (redis://redis:6379/0)
# Production: bắt buộc có password, REDIS_URL sẽ tự build từ REDIS_PASSWORD
# Sinh: python -c "import secrets; print(secrets.token_hex(24))"
REDIS_PASSWORD=              # production: bắt buộc đặt; dev: để trống
REDIS_URL=redis://redis:6379/0
# Khi có REDIS_PASSWORD, đặt: REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ── MinIO ─────────────────────────────────────────────────────────────────────
# Dev/local compose:
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_SECURE=false               # true cho production có TLS
# MINIO_BUCKET=                  # bỏ trống = tự động theo ENVIRONMENT
# Production: bắt buộc override toàn bộ `MINIO_*` sang endpoint object storage thật.
# Ví dụ:
# MINIO_ENDPOINT=s3.hongha.vn
# MINIO_ACCESS_KEY=CHANGE_ME_PROD
# MINIO_SECRET_KEY=CHANGE_ME_PROD
# MINIO_SECURE=true
# MINIO_BUCKET=hrms-attachments-prod

# ── Backup Scheduler ──────────────────────────────────────────────────────────
# Backup storage đích cho cả DB dump và snapshot object storage.
BACKUP_STORAGE_ENDPOINT=
BACKUP_STORAGE_ACCESS_KEY=
BACKUP_STORAGE_SECRET_KEY=
BACKUP_STORAGE_SECURE=true
BACKUP_STORAGE_BUCKET=hrms-backup
BACKUP_TEMP_DIR=/backups/tmp
BACKUP_RETENTION_DAYS=90
DB_BACKUP_CRON=0 2 * * *
MINIO_BACKUP_CRON=0 3 * * *
# Optional override source alias / creds nếu khác object storage ứng dụng chính
SOURCE_ALIAS=local
SOURCE_STORAGE_ENDPOINT=
SOURCE_STORAGE_ACCESS_KEY=
SOURCE_STORAGE_SECRET_KEY=
SOURCE_STORAGE_SECURE=
DEST_ALIAS=backup
BACKUP_NOTIFY_EMAILS=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Production: thay bằng domain frontend thực tế, ví dụ:
# CORS_ORIGINS=["https://hrms.honghafeed.com.vn"]
# Nếu chạy nội bộ LAN không có DNS nội bộ, có thể set IP tĩnh và map file hosts trên máy user:
# 172.16.2.100 hrms.honghafeed.com.vn
# Khi đó:
# HTTPS nội bộ:
# CORS_ORIGINS=["https://hrms.honghafeed.com.vn"]
# HTTP-only nội bộ:
# CORS_ORIGINS=["http://hrms.honghafeed.com.vn","http://172.16.2.100"]
# Nếu có nhiều origin hợp lệ, dùng JSON array đầy đủ.
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:3000","http://127.0.0.1:3000"]

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_USE_STARTTLS=false
SMTP_FROM_EMAIL=no-reply@hrms.local
SMTP_FROM_NAME=Hồng Hà HRMS

# ── Production bootstrap admin ───────────────────────────────────────────────
# Dùng cho lệnh: make seed-bootstrap-admin
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_FULL_NAME=
BOOTSTRAP_ADMIN_PASSWORD=

# ── File Upload ───────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=                      # https://xxx@sentry.io/yyy  (bỏ trống = disabled)
HEALTHCHECK_PING_URL=            # https://hc-ping.com/xxx    (bỏ trống = disabled)

# ── Frontend (dev only) ───────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1
