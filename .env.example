# HRMS Environment Variables — copy sang .env và điền giá trị thực
# KHÔNG commit file .env vào git

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
DEBUG=false
COMPANY_NAME=Công ty Hồng Hà

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=hrms

# DB Connection Pool (tuned for ~200 concurrent users)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true

# ── Security ──────────────────────────────────────────────────────────────────
# Sinh: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_USE_RANDOM_64_CHAR_HEX

# Sinh Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_SECURE=false               # true cho production có TLS
# MINIO_BUCKET=                  # bỏ trống = tự động theo ENVIRONMENT

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_USE_STARTTLS=false
SMTP_FROM_EMAIL=no-reply@hrms.local
SMTP_FROM_NAME=Hồng Hà HRMS

# ── File Upload ───────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=                      # https://xxx@sentry.io/yyy  (bỏ trống = disabled)
HEALTHCHECK_PING_URL=            # https://hc-ping.com/xxx    (bỏ trống = disabled)

# ── Frontend (dev only) ───────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1
